{
  "$schema": "https://static.cloudbase.net/cli/cloudbaserc.schema.json",
  "version": "2.0",
  "envId": "your-env-id",
  "region": "ap-shanghai",
  "functionRoot": "cloudfunctions",
  "functionDefaultConfig": {
    "runtime": "Nodejs18.15",
    "timeout": 60,
    "memorySize": 256,
    "handler": "index.main",
    "installDependency": true
  },
  "functions": [
    {
      "name": "elderCareApi",
      "description": "东软颐养中心 API（MySQL 持久化）",
      "timeout": 60,
      "memorySize": 512,
      "envVariables": {
        "DB_NAME": "your-database-name",
        "DB_HOST": "your-vpc-mysql-host",
        "DB_PORT": "3306",
        "DB_USER": "eldercare",
        "DB_PASSWORD": "YOUR_PASSWORD_HERE"
      },
      "vpc": {
        "vpcId": "your-vpc-id",
        "subnetId": "your-subnet-id"
      }
    }
  ]
}
